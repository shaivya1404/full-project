FROM python:3.11-slim

WORKDIR /app

COPY admin-api/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY admin-api/ ./admin_api/
COPY admin-api/app.py ./app.py

ENV PYTHONPATH=/app
ENV ADMIN_API_PORT=8006

EXPOSE 8006
CMD ["uvicorn", "admin_api.app:app", "--host", "0.0.0.0", "--port", "8006"]
