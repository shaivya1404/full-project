FROM python:3.11-slim

WORKDIR /app

COPY tool-middleware/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY tool-middleware/ ./tool_middleware/
COPY tool-middleware/app.py ./app.py

ENV PYTHONPATH=/app
ENV TOOL_MIDDLEWARE_PORT=8005

EXPOSE 8005
CMD ["uvicorn", "tool_middleware.app:app", "--host", "0.0.0.0", "--port", "8005"]
