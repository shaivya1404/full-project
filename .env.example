# ── Database & Cache ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require
REDIS_URL=redis://localhost:6379

# ── Internal service URLs ──────────────────────────────────────────────────────
STT_SERVICE_URL=http://localhost:8002
EMOTION_SERVICE_URL=http://localhost:8003
TOOL_MIDDLEWARE_URL=http://localhost:8005
ADMIN_API_URL=http://localhost:8006

# ── LLM — switch between Groq and local by changing these 3 lines only ────────
#
# MODE 1: Groq (use now)
#   Get free key at console.groq.com
LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=YOUR_GROQ_API_KEY
LLM_MODEL=qwen/qwen3-32b
#
# MODE 2: Local vLLM (use later, when your GPU machine is ready)
#   Run: python -m vllm.entrypoints.openai.api_server --model Qwen/Qwen2.5-32B-Instruct
#   Then flip these 3 lines:
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=Qwen/Qwen2.5-32B-Instruct

# ── STT fine-tuned model path ─────────────────────────────────────────────────
# Point to your whisper-stt-finetuned/ directory (the LoRA adapter weights)
LORA_MODEL_PATH=/models/stt/whisper-stt-finetuned

# ── Cartesia TTS ──────────────────────────────────────────────────────────────
CARTESIA_API_KEY=YOUR_CARTESIA_API_KEY

# ── Agent server ──────────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8010
VAD_SILENCE_MS=600

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
DEVICE=cpu
