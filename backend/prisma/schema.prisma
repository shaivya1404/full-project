generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  name          String         @map("name")
  slug          String         @unique @map("slug")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  apiKeys       TtsApiKey[]
  audioFiles    AudioFile[]
  sttJobs       SttJob[]
  ttsJobs       TtsJob[]
  usageRecords  UsageRecord[]
  users         TtsUser[]
  voiceProfiles VoiceProfile[]

  @@map("organizations")
}

model TtsUser {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  email        String       @map("email")
  passwordHash String       @map("password_hash")
  role         UserRole     @default(developer) @map("role")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  audioFiles   AudioFile[]
  sttJobs      SttJob[]
  ttsJobs      TtsJob[]
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([orgId, email])
  @@map("users")
}

model TtsApiKey {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  orgId              String        @map("org_id") @db.Uuid
  keyHash            String        @unique @map("key_hash")
  name               String        @map("name")
  scopes             String[]      @default([]) @map("scopes")
  rateLimitPerMinute Int?          @map("rate_limit_per_minute")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  lastUsedAt         DateTime?     @map("last_used_at") @db.Timestamptz(6)
  revokedAt          DateTime?     @map("revoked_at") @db.Timestamptz(6)
  organization       Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sttJobs            SttJob[]
  ttsJobs            TtsJob[]
  usageRecords       UsageRecord[]

  @@map("api_keys")
}

model VoiceProfile {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  orgId                String             @map("org_id") @db.Uuid
  name                 String             @map("name")
  language             String             @map("language")
  gender               String?            @map("gender")
  description          String?            @map("description")
  baseModel            String             @map("base_model")
  speakerEmbeddingPath String?            @map("speaker_embedding_path")
  status               VoiceProfileStatus @default(training) @map("status")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  ttsJobs              TtsJob[]
  organization         Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("voice_profiles")
}

model AudioFile {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  orgId           String        @map("org_id") @db.Uuid
  userId          String?       @map("user_id") @db.Uuid
  type            AudioFileType @map("type")
  storagePath     String        @map("storage_path")
  mimeType        String        @map("mime_type")
  durationSeconds Float?        @map("duration_seconds")
  sizeBytes       BigInt?       @map("size_bytes")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  organization    Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user            TtsUser?      @relation(fields: [userId], references: [id], onUpdate: NoAction)
  sttInputJobs    SttJob[]      @relation("SttJobInputAudio")
  ttsResultJobs   TtsJob[]      @relation("TtsJobResultAudio")

  @@map("audio_files")
}

model TtsJob {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  orgId             String        @map("org_id") @db.Uuid
  userId            String?       @map("user_id") @db.Uuid
  apiKeyId          String?       @map("api_key_id") @db.Uuid
  inputText         String        @map("input_text")
  language          String        @map("language")
  voiceProfileId    String?       @map("voice_profile_id") @db.Uuid
  emotion           String?       @map("emotion")
  speed             Float?        @map("speed")
  status            JobStatus     @default(queued) @map("status")
  resultAudioFileId String?       @map("result_audio_file_id") @db.Uuid
  errorMessage      String?       @map("error_message")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  completedAt       DateTime?     @map("completed_at") @db.Timestamptz(6)
  apiKey            TtsApiKey?    @relation(fields: [apiKeyId], references: [id], onUpdate: NoAction)
  organization      Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  resultAudioFile   AudioFile?    @relation("TtsJobResultAudio", fields: [resultAudioFileId], references: [id], onUpdate: NoAction)
  user              TtsUser?      @relation(fields: [userId], references: [id], onUpdate: NoAction)
  voiceProfile      VoiceProfile? @relation(fields: [voiceProfileId], references: [id], onUpdate: NoAction)

  @@map("tts_jobs")
}

model SttJob {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  orgId            String         @map("org_id") @db.Uuid
  userId           String?        @map("user_id") @db.Uuid
  apiKeyId         String?        @map("api_key_id") @db.Uuid
  inputAudioFileId String         @map("input_audio_file_id") @db.Uuid
  languageDetected String?        @map("language_detected")
  modelUsed        String         @map("model_used")
  status           JobStatus      @default(queued) @map("status")
  errorMessage     String?        @map("error_message")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  completedAt      DateTime?      @map("completed_at") @db.Timestamptz(6)
  apiKey           TtsApiKey?     @relation(fields: [apiKeyId], references: [id], onUpdate: NoAction)
  inputAudioFile   AudioFile      @relation("SttJobInputAudio", fields: [inputAudioFileId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user             TtsUser?       @relation(fields: [userId], references: [id], onUpdate: NoAction)
  transcription    Transcription?

  @@map("stt_jobs")
}

model Transcription {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  sttJobId   String   @unique @map("stt_job_id") @db.Uuid
  text       String   @map("text")
  language   String   @map("language")
  confidence Float    @map("confidence")
  timestamps Json     @map("timestamps")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  sttJob     SttJob   @relation(fields: [sttJobId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("transcriptions")
}

model UsageRecord {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  apiKeyId     String?      @map("api_key_id") @db.Uuid
  type         UsageType    @map("type")
  units        Float        @map("units")
  metadata     Json?        @map("metadata")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  apiKey       TtsApiKey?   @relation(fields: [apiKeyId], references: [id], onUpdate: NoAction)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("usage_records")
}

model MlModel {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  name      String        @map("name")
  type      MlModelType   @map("type")
  version   String        @map("version")
  status    MlModelStatus @default(loading) @map("status")
  config    Json?         @map("config")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([name, type, version])
  @@map("ml_models")
}

model Agent {
  id                 String         @id @default(cuid())
  teamId             String?
  name               String
  email              String         @unique
  phone              String?
  role               String         @default("agent")
  availabilityStatus String         @default("offline")
  skills             String?
  maxConcurrentCalls Int            @default(1)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime @updatedAt
  team               Team?          @relation(fields: [teamId], references: [id])
  agentSessions       AgentSession[]
  callQueues          CallQueue[]
}

model AgentSession {
  id        String    @id @default(cuid())
  agentId   String
  callId    String
  startTime DateTime  @default(now())
  endTime   DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  call      Call      @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([callId])
}

model Analytics {
  id             String   @id @default(cuid())
  callId         String
  sentiment      String?
  sentimentScore Float?
  talkTime       Float?
  silenceTime    Float?
  interruptions  Int?
  averageLatency Float?
  metrics        String?
  snapshotTime   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  call           Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
}

model ApiKey {
  id         String    @id @default(cuid())
  key        String    @unique
  name       String
  userId     String
  teamId     String?
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime @updatedAt
  team       Team?     @relation(fields: [teamId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([teamId])
  @@index([userId])
}

model ApologyTemplate {
  id                 String   @id @default(cuid())
  teamId             String
  situation          String
  isSpecific         Boolean  @default(true)
  template           String
  followUpAction     String?
  usageCount         Int      @default(0)
  effectivenessScore Float    @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  team               Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([situation])
  @@index([teamId])
}

model AuditLog {
  id           String   @id @default(cuid())
  teamId       String?
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  details      String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  team         Team?    @relation(fields: [teamId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([teamId])
  @@index([userId])
}

model Call {
  id                  String                @id @default(cuid())
  streamSid           String                @unique
  callSid             String?               @unique
  caller              String
  agent               String?
  startTime           DateTime              @default(now())
  endTime             DateTime?
  duration            Int?
  status              String                @default("active")
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime @updatedAt
  teamId              String?
  agentSessions        AgentSession[]
  analytics            Analytics[]
  team                Team?                 @relation(fields: [teamId], references: [id])
  metadata            CallMetadata?
  callQueue           CallQueue?
  complaints           Complaint[]
  conversationState   ConversationState?
  factVerifications    FactVerification[]
  knowledgeBaseSources KnowledgeBaseSource[]
  orders               Order[]
  recordings           Recording[]
  transcripts          Transcript[]
  transferLogs         TransferLog[]
}

model CallLog {
  id                String              @id @default(cuid())
  campaignId        String
  contactId         String
  duration          Int?
  result            String              @default("pending")
  recordingUrl      String?
  transcript        String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime @updatedAt
  sentimentScore    Float?
  escalationReason  String?
  wasEscalated      Boolean             @default(false)
  campaign          Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact           Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  callObjections     CallObjection[]
  followUpExecutions FollowUpExecution[]
}

model CallMetadata {
  id             String   @id @default(cuid())
  callId         String   @unique
  language       String?
  region         String?
  deviceType     String?
  networkQuality String?
  customData     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  call           Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
}

model CallObjection {
  id            String    @id @default(cuid())
  callLogId     String
  objectionType String
  objectionText String?
  responseUsed  String?
  wasResolved   Boolean   @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  callLog       CallLog   @relation(fields: [callLogId], references: [id], onDelete: Cascade)

  @@index([callLogId])
  @@index([objectionType])
}

model CallQueue {
  id                String   @id @default(cuid())
  teamId            String?
  callId            String   @unique
  reasonForTransfer String?
  priority          Int      @default(0)
  status            String   @default("waiting")
  assignedAgentId   String?
  waitTime          Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  agent             Agent?   @relation(fields: [assignedAgentId], references: [id])
  call              Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  team              Team?    @relation(fields: [teamId], references: [id])

  @@index([status])
  @@index([teamId])
}

model CallbackSchedule {
  id            String    @id @default(cuid())
  teamId        String
  contactId     String
  campaignId    String?
  scheduledTime DateTime
  timezone      String    @default("Asia/Kolkata")
  reason        String?
  priority      Int       @default(0)
  status        String    @default("pending")
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  completedAt   DateTime?
  resultCallId  String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime @updatedAt
  campaign      Campaign? @relation(fields: [campaignId], references: [id])
  contact       Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  team          Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([contactId])
  @@index([scheduledTime])
  @@index([status])
  @@index([teamId])
}

model Campaign {
  id                String             @id @default(cuid())
  name              String
  description       String?
  status            String             @default("draft")
  script            String
  startDate         DateTime?
  endDate           DateTime?
  dailyLimit        Int                @default(100)
  retryAttempts     Int                @default(3)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime @updatedAt
  teamId            String?
  callLogs           CallLog[]
  callbackSchedules  CallbackSchedule[]
  team              Team?              @relation(fields: [teamId], references: [id])
  campaignAnalytics CampaignAnalytics?
  contacts           Contact[]
  followUpSequences  FollowUpSequence[]
  orders             Order[]
}

model CampaignAnalytics {
  id          String   @id @default(cuid())
  campaignId  String   @unique
  successRate Float    @default(0)
  roi         Float    @default(0)
  cost        Float    @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Complaint {
  id                  String                @id @default(cuid())
  teamId              String
  ticketNumber        String                @unique
  customerId          String?
  orderId             String?
  callId              String?
  category            String
  subcategory         String?
  priority            String                @default("medium")
  status              String                @default("open")
  subject             String
  description         String
  customerPhone       String?
  customerEmail       String?
  customerName        String?
  assignedTo          String?
  assignedAt          DateTime?
  resolution          String?
  resolutionType      String?
  compensationAmount  Float?
  resolvedBy          String?
  resolvedAt          DateTime?
  customerSatisfied   Boolean?
  feedbackScore       Int?
  feedbackComment     String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime @updatedAt
  closedAt            DateTime?
  slaDeadline         DateTime?
  slaBreach           Boolean               @default(false)
  firstResponseAt     DateTime?
  call                Call?                 @relation(fields: [callId], references: [id])
  customer            Customer?             @relation(fields: [customerId], references: [id])
  order               Order?                @relation(fields: [orderId], references: [id])
  team                Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  attachments ComplaintAttachment[]
  comments    ComplaintComment[]
  history    ComplaintHistory[]

  @@index([assignedTo])
  @@index([createdAt])
  @@index([customerId])
  @@index([orderId])
  @@index([priority])
  @@index([status])
  @@index([teamId])
  @@index([ticketNumber])
}

model ComplaintAttachment {
  id          String    @id @default(cuid())
  complaintId String
  fileName    String
  fileUrl     String
  fileType    String
  fileSize    Int
  uploadedBy  String?
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
}

model ComplaintCategory {
  id              String   @id @default(cuid())
  teamId          String
  name            String
  description     String?
  subcategories   String?
  defaultPriority String   @default("medium")
  slaHours        Int      @default(24)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, name])
  @@index([teamId])
}

model ComplaintComment {
  id          String    @id @default(cuid())
  complaintId String
  authorId    String?
  authorName  String
  authorType  String
  content     String
  isInternal  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@index([createdAt])
}

model ComplaintHistory {
  id              String    @id @default(cuid())
  complaintId     String
  action          String
  fromValue       String?
  toValue         String?
  performedBy     String?
  performedByName String?
  note            String?
  createdAt       DateTime  @default(now())
  complaint       Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@index([createdAt])
}

model ComplianceLog {
  id          String   @id @default(cuid())
  teamId      String?
  callId      String?
  phoneNumber String
  checkType   String
  checkResult String
  details     String?
  createdAt   DateTime @default(now())

  @@index([checkType])
  @@index([createdAt])
  @@index([phoneNumber])
  @@index([teamId])
}

model Contact {
  id                String              @id @default(cuid())
  campaignId        String?
  phone             String
  name              String?
  email             String?
  isValid           Boolean             @default(false)
  isDoNotCall       Boolean             @default(false)
  validationError   String?
  metadata          String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime @updatedAt
  leadScore         Int                 @default(0)
  leadTier          String              @default("unknown")
  leadSource        String?
  interestLevel     Int                 @default(0)
  buyingSignals     String?
  lastScoredAt      DateTime?
  totalCalls        Int                 @default(0)
  successfulCalls   Int                 @default(0)
  lastContactedAt   DateTime?
  preferredCallTime String?
  timezone          String?
  callLogs           CallLog[]
  callbackSchedules  CallbackSchedule[]
  campaign          Campaign?           @relation(fields: [campaignId], references: [id])
  contactConsents    ContactConsent[]
  followUpExecutions FollowUpExecution[]
}

model ContactConsent {
  id            String    @id @default(cuid())
  contactId     String
  consentType   String
  consentGiven  Boolean
  consentDate   DateTime
  consentMethod String
  expiresAt     DateTime?
  recordingUrl  String?
  createdAt     DateTime  @default(now())
  contact       Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([consentType])
  @@index([contactId])
}

model ConversationState {
  id                   String   @id @default(cuid())
  callId               String   @unique
  streamSid            String   @unique
  customerId           String?
  collectedFields      String   @default("{}")
  pendingConfirmations String?
  questionHistory      String   @default("[]")
  responseHistory      String   @default("[]")
  loopDetected         Boolean  @default(false)
  loopType             String?
  currentEmotion       String   @default("neutral")
  emotionScore         Float    @default(0.5)
  emotionHistory       String?
  conversationStage    String   @default("greeting")
  progressPercentage   Int      @default(0)
  stepsCompleted       String?
  stepsRemaining       String?
  apologyGiven         Boolean  @default(false)
  apologyReason        String?
  promisesMade         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  call                 Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
}

model Customer {
  id                 String              @id @default(cuid())
  teamId             String?
  phone              String?
  email              String?
  address            String?
  name               String?
  previousOrders     Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime @updatedAt
  complaints          Complaint[]
  team               Team?               @relation(fields: [teamId], references: [id])
  customerLoyalty    CustomerLoyalty?
  customerMemories     CustomerMemory[]
  customerPreference CustomerPreference?
  orders              Order[]
  payments            Payment[]
  smsLogs             SmsLog[]

  @@index([email])
  @@index([phone])
  @@index([teamId])
}

model CustomerLoyalty {
  id                  String               @id @default(cuid())
  customerId          String               @unique
  teamId              String
  tierId              String?
  totalPointsEarned   Int                  @default(0)
  totalPointsRedeemed Int                  @default(0)
  currentPoints       Int                  @default(0)
  lifetimeValue       Float                @default(0)
  totalOrders         Int                  @default(0)
  lastOrderAt         DateTime?
  memberSince         DateTime             @default(now())
  referralCode        String?              @unique
  referredBy          String?
  referralCount       Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime @updatedAt
  customer            Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  team                Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  loyaltyTier         LoyaltyTier?         @relation(fields: [tierId], references: [id])
  loyaltyTransactions  LoyaltyTransaction[]
  rewardRedemptions    RewardRedemption[]

  @@index([customerId])
  @@index([referralCode])
  @@index([teamId])
  @@index([tierId])
}

model CustomerMemory {
  id         String    @id @default(cuid())
  customerId String
  teamId     String
  factType   String
  factKey    String
  factValue  String
  confidence Float     @default(1.0)
  source     String
  learnedAt  DateTime  @default(now())
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, factType, factKey])
  @@index([customerId])
